<body class="opera">






    <header id="header"
            class="hf hf__header">
        
    </header>

    
    <main class="thanks-page px-20 px-md-40 py-32 flex flex-direction--column between-xs">
        <div class="flex between-xs">
            
                <a href="/fr">
                    <i class="icon-component "
   data-icon-name="Opera (text)"
   data-icon-type="Logo"
   data-icon-alt="Opera (text)"
   data-icon-width=""></i>

                </a>
            
            <span id="back-button" class="back">
                <svg xmlns="http://www.w3.org/2000/svg" width="41" height="40" viewBox="0 0 41 40" fill="none">
                    <path d="M24 12L40 28M40 12L24 28" stroke="black" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
        </div>
        <section class="width-100">
            <div class="px-md-56">
                
                    <h1 class="text-32 text-md-40 line-height-40 line-height-md-52 font-weight--900 mt-0 mb-md-96">Votre nouveau navigateur Opera <span class="color--cobalt-blue">est prêt à être installé</span></h1>

                

                <div class="bar hidden--to-md"></div>

                <div class="mt-40">
                    <div class="steps">
                        <div>
                            <span class="count mr-16">1</span>
                            <div class="block--inline-block">
                                <div class="font-mono text-10 font-weight--700 text-transform--uppercase color--hover-color">
                                
                                    Etape 1
                                
                                </div>
                                <p class="text-16 font-weight--700 mb-0 step_description">
                                    
                                        Ouvrez le fichier <i>OperaSetup</i>
                                    
                                </p>
                            </div>
                        </div>
                        <div class="step__arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="41" height="40" viewBox="0 0 41 30"
                                 fill="none">
                                <path d="M8.25 19C7.69772 19 7.25 19.4477 7.25 20C7.25 20.5523 7.69772 21 8.25 21V19ZM32.9571 20.7071C33.3476 20.3166 33.3476 19.6834 32.9571 19.2929L26.5931 12.9289C26.2026 12.5384 25.5695 12.5384 25.1789 12.9289C24.7884 13.3195 24.7884 13.9526 25.1789 14.3431L30.8358 20L25.1789 25.6569C24.7884 26.0474 24.7884 26.6805 25.1789 27.0711C25.5695 27.4616 26.2026 27.4616 26.5931 27.0711L32.9571 20.7071ZM8.25 21H32.25V19H8.25V21Z"
                                      fill="#D0DBE3"/>
                            </svg>
                        </div>
                        <div>
                            <span class="count mr-16">2</span>
                            <div class="block--inline-block">
                                <div class="font-mono text-10 font-weight--700 text-transform--uppercase color--hover-color">
                                
                                    Etape 2
                                
                                </div>
                                <p class="text-16 font-weight--700 mb-0 step_description">
                                
                                    Suivez les instructions
                                
                                </p>
                            </div>
                        </div>
                        <div class="step__arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="41" height="40" viewBox="0 0 41 30"
                                 fill="none">
                                <path d="M8.25 19C7.69772 19 7.25 19.4477 7.25 20C7.25 20.5523 7.69772 21 8.25 21V19ZM32.9571 20.7071C33.3476 20.3166 33.3476 19.6834 32.9571 19.2929L26.5931 12.9289C26.2026 12.5384 25.5695 12.5384 25.1789 12.9289C24.7884 13.3195 24.7884 13.9526 25.1789 14.3431L30.8358 20L25.1789 25.6569C24.7884 26.0474 24.7884 26.6805 25.1789 27.0711C25.5695 27.4616 26.2026 27.4616 26.5931 27.0711L32.9571 20.7071ZM8.25 21H32.25V19H8.25V21Z"
                                      fill="#D0DBE3"/>
                            </svg>
                        </div>
                        <div>
                            <span class="count mr-16">3</span>
                            <div class="block--inline-block">
                                <div class="font-mono text-10 font-weight--700 text-transform--uppercase color--hover-color">
                                    
                                        Etape 3
                                    
                                </div>
                                <p class="text-16 font-weight--700 mb-0 step_description">
                                    
                                        Profitez du navigateur Opera
                                    
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <p class="info-message text-10 px-md-56 ">
            
                Si le téléchargement n’a pas démarré automatiquement, <a href="https://download.opera.com/download/get/?id=78819&amp;location=415&amp;nothanks=yes&amp;sub=marine&amp;utm_tryagain=yes" id="thanks-download-link" data-event-action="thanks-download-link-default">clique ici</a>.
            
        </p>
    </main>


    
